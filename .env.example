# Hearth backend config. Copy to .env. Secrets via sops+age:
# `make secrets-encrypt` / `secrets-decrypt` (.env <-> .env.enc; recipient in .sops.yaml).

# Postgres
POSTGRES_USER=hearth
POSTGRES_PASSWORD=hearth
POSTGRES_DB=hearth

# Dev path (cargo run); compose.yml overrides to the in-network address.
DATABASE_URL=postgres://hearth:hearth@localhost:5433/hearth

# JWT_SECRET: generate with: openssl rand -base64 48
JWT_SECRET=dev-only-change-me-min-32-bytes-long-secret
ACCESS_TTL_SECS=900
REFRESH_TTL_SECS=2592000
BACKEND_PORT=8080

# Reserved for later milestones:
# S3_ENDPOINT=
# TURN_SECRET=
